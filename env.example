# Database
DATABASE_URL="postgresql://user:password@localhost:5432/dbname"

# JWT
JWT_SECRET="your-secret-key-at-least-32-chars"

# App URL (used in email links)
NEXT_PUBLIC_APP_URL="https://yourdomain.com"

# Backblaze B2 Storage (optional - falls back to local filesystem if not set)
B2_APPLICATION_KEY_ID="your_key_id"
B2_APPLICATION_KEY="your_application_key"
B2_BUCKET_ID="your_bucket_id"
B2_BUCKET_NAME="your_bucket_name"
# B2_PUBLIC_URL="https://f004.backblazeb2.com"  # Optional: override if using custom domain

# Zoho Mail — SMTP (for password reset, notifications)
# Add your Zoho credentials in .env.local (never commit real credentials)
ZOHO_SMTP_HOST=smtp.zoho.com
ZOHO_SMTP_PORT=587
ZOHO_SMTP_USER=noreply@yourdomain.com
ZOHO_SMTP_PASS=your_zoho_app_password
ZOHO_FROM_NAME=Rwanda Drone Community

# Weather: No API key needed — uses Open-Meteo (free/open-source) + aviationweather.gov METAR/TAF
